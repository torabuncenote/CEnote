{
  "rules": {
    "data":        { ".read": "auth != null", ".write": "auth != null" },
    "board": {
      ".read": "auth != null",
      "$postId": {
        ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid || root.child('admins').child(auth.uid).val() === true)",
        "reads": {
          "$uid": { ".write": "auth != null && auth.uid === $uid" }
        },
        "replies": {
          "$replyId": { ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid || root.child('admins').child(auth.uid).val() === true)" }
        }
      }
    },
    "backups":       { ".read": "auth != null", "$date": { ".write": "auth != null" } },
    "backup_meta":   { ".read": "auth != null", "$date": { ".write": "auth != null" } },
    "recent_backup": { ".read": "root.child('admins').child(auth.uid).val() === true", ".write": "auth != null" },
    "logs": {
      ".read": "auth != null",
      "$logId": { ".write": "auth != null && (!data.exists() || root.child('admins').child(auth.uid).val() === true)" }
    },
    "admins": { ".read": "auth != null", "$uid": { ".write": "root.child('admins').child(auth.uid).val() === true" } },
    "users":  { ".read": "auth != null", "$uid": { ".write": "auth.uid === $uid || root.child('admins').child(auth.uid).val() === true" } },
    "userPerms": {
      ".read": "root.child('admins').child(auth.uid).val() === true",
      "$uid": { ".read": "auth.uid === $uid", ".write": "root.child('admins').child(auth.uid).val() === true" }
    },
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$notifId": { ".write": "auth != null && (!data.exists() || auth.uid === $uid)" }
      }
    },
    "fcmTokens": {
      ".read": "auth != null",
      "$uid": { ".write": "auth != null && auth.uid === $uid" }
    }
  }
}
